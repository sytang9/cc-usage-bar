#!/usr/bin/env bash
# ccswitch: save, list, switch between, and delete Claude Code accounts by
# swapping the OAuth credential files Claude Code reads from $HOME.
#
# Storage layout:
#   $HOME/.claude/accounts/<label>/credentials.json   (copy of live .credentials.json)
#   $HOME/.claude/accounts/<label>/oauthAccount.json  (the .oauthAccount object from .claude.json)
#
# SECURITY: never print token values or credential file contents. All moves
# use cp/jq, never echo of secret fields.
set -uo pipefail

: "${HOME:?HOME must be set}"

CLAUDE_DIR="$HOME/.claude"
CLAUDE_JSON="$HOME/.claude.json"
CREDENTIALS_FILE="$CLAUDE_DIR/.credentials.json"
ACCOUNTS_DIR="$CLAUDE_DIR/accounts"

RESERVED_WORDS=(save delete list usage)
# Whitelist charset for labels. Deliberately strict: this is what stands
# between a label and a raw filesystem path ($ACCOUNTS_DIR/$label), so it
# must reject '/' and '.' outright rather than trying to blocklist "..".
LABEL_CHARSET_PATTERN='^[A-Za-z0-9_-]+$'

# is_dash_prefixed_label <label>: true if the label starts with '-' (would
# read as a CLI flag rather than a label). NOTE: '-' is itself inside
# LABEL_CHARSET_PATTERN's allowed set (for mid-label hyphens like
# "my-label"), so this leading-dash rule has to be enforced separately from
# the charset check below -- the charset regex alone would accept "-foo".
is_dash_prefixed_label() {
  case "$1" in
    -*) return 0 ;;
    *) return 1 ;;
  esac
}

# is_reserved_label <label>: true if the label collides with a reserved
# subcommand name.
is_reserved_label() {
  local label="$1" reserved
  for reserved in "${RESERVED_WORDS[@]}"; do
    [[ "$label" == "$reserved" ]] && return 0
  done
  return 1
}

# validate_label <label>: exits with a clear message and non-zero status
# unless the label is non-empty, made up only of [A-Za-z0-9_-], not
# dash-prefixed, and not a reserved subcommand name. Every code path that
# turns a label into a filesystem path (save/switch/delete) MUST call this
# before touching $ACCOUNTS_DIR/$label -- that path is built by direct
# string concatenation, so an unvalidated label (e.g. "../../etc") is a
# path-traversal vector into mkdir/cp/rm -rf.
validate_label() {
  local label="$1"
  if [[ -z "$label" ]]; then
    echo "Error: label is required." >&2
    exit 1
  fi
  if is_dash_prefixed_label "$label"; then
    echo "Error: '$label' looks like an option flag and cannot be used as a label." >&2
    exit 1
  fi
  if ! [[ "$label" =~ $LABEL_CHARSET_PATTERN ]]; then
    echo "Error: '$label' is not a valid label -- only letters, digits, '_' and '-' are allowed." >&2
    exit 1
  fi
  if is_reserved_label "$label"; then
    echo "Error: '$label' is a reserved word and cannot be used as a label." >&2
    exit 1
  fi
}

require_claude_json() {
  if [[ ! -f "$CLAUDE_JSON" ]]; then
    echo "Error: $CLAUDE_JSON not found." >&2
    exit 1
  fi
  if ! jq empty "$CLAUDE_JSON" >/dev/null 2>&1; then
    echo "Error: $CLAUDE_JSON is not valid JSON." >&2
    exit 1
  fi
}

require_live_credentials() {
  if [[ ! -f "$CREDENTIALS_FILE" ]]; then
    echo "Error: no active credentials found at $CREDENTIALS_FILE." >&2
    exit 1
  fi
}

# secure_dir <path>: create a directory (if missing) and force mode 700.
secure_dir() {
  local dir="$1"
  mkdir -p "$dir"
  chmod 700 "$dir"
}

# secure_copy <src> <dst>: copy a file and force mode 600 on the destination.
secure_copy() {
  local src="$1" dst="$2"
  cp "$src" "$dst"
  chmod 600 "$dst"
}

live_refresh_token() {
  jq -r '.claudeAiOauth.refreshToken // empty' "$CREDENTIALS_FILE" 2>/dev/null
}

saved_refresh_token() {
  local label="$1"
  jq -r '.claudeAiOauth.refreshToken // empty' "$ACCOUNTS_DIR/$label/credentials.json" 2>/dev/null
}

confirm() {
  local prompt="$1" answer
  read -r -p "$prompt [y/N] " answer
  case "$answer" in
    y | Y | yes | YES) return 0 ;;
    *) return 1 ;;
  esac
}

cmd_save() {
  local label="${1:-}"

  validate_label "$label"

  require_claude_json
  require_live_credentials

  secure_dir "$ACCOUNTS_DIR"

  local label_dir="$ACCOUNTS_DIR/$label"
  if [[ -d "$label_dir" ]]; then
    if ! confirm "Account '$label' already exists. Overwrite?"; then
      echo "Aborted."
      exit 0
    fi
  fi
  secure_dir "$label_dir"

  secure_copy "$CREDENTIALS_FILE" "$label_dir/credentials.json"

  local tmp_oauth
  tmp_oauth="$(mktemp "${TMPDIR:-/tmp}/ccswitch-oauth.XXXXXX")"
  jq '.oauthAccount // {}' "$CLAUDE_JSON" >"$tmp_oauth"
  secure_copy "$tmp_oauth" "$label_dir/oauthAccount.json"
  rm -f "$tmp_oauth"

  echo "Saved account '$label'."
}

cmd_list() {
  if [[ ! -d "$ACCOUNTS_DIR" ]] || [[ -z "$(ls -A "$ACCOUNTS_DIR" 2>/dev/null)" ]]; then
    echo "no saved accounts -- run: ccswitch save <label>"
    return 0
  fi

  local live_refresh=""
  if [[ -f "$CREDENTIALS_FILE" ]]; then
    live_refresh="$(live_refresh_token)"
  fi

  local label_dir label
  for label_dir in "$ACCOUNTS_DIR"/*/; do
    label="$(basename "$label_dir")"
    if [[ -n "$live_refresh" ]] && [[ "$(saved_refresh_token "$label")" == "$live_refresh" ]]; then
      echo "* $label"
    else
      echo "  $label"
    fi
  done
}

cmd_delete() {
  local label="${1:-}"

  validate_label "$label"

  local label_dir="$ACCOUNTS_DIR/$label"
  if [[ ! -d "$label_dir" ]]; then
    echo "Error: no saved account named '$label'." >&2
    exit 1
  fi

  if confirm "Delete account '$label'?"; then
    rm -rf "$label_dir"
    echo "Deleted account '$label'."
  else
    echo "Aborted."
  fi
}

cmd_switch() {
  local label="$1" relaunch="${2:-}"

  validate_label "$label"

  local label_dir="$ACCOUNTS_DIR/$label"

  if [[ ! -d "$label_dir" ]]; then
    echo "Error: no saved account named '$label'. Run: ccswitch save $label" >&2
    exit 1
  fi
  if [[ ! -f "$label_dir/credentials.json" ]]; then
    echo "Error: saved account '$label' is missing credentials.json." >&2
    exit 1
  fi

  require_claude_json

  mkdir -p "$CLAUDE_DIR"
  chmod 700 "$CLAUDE_DIR"

  if [[ -f "$CREDENTIALS_FILE" ]]; then
    secure_copy "$CREDENTIALS_FILE" "$CREDENTIALS_FILE.bak"
  fi

  secure_copy "$label_dir/credentials.json" "$CREDENTIALS_FILE"

  local oauth_account_file="$label_dir/oauthAccount.json"
  if [[ -f "$oauth_account_file" ]]; then
    local tmp_claude_json
    tmp_claude_json="$(mktemp "${TMPDIR:-/tmp}/ccswitch-claude.XXXXXX")"
    jq --slurpfile oauth "$oauth_account_file" '.oauthAccount = $oauth[0]' "$CLAUDE_JSON" >"$tmp_claude_json"
    mv "$tmp_claude_json" "$CLAUDE_JSON"
  fi

  echo "Switched to $label. Restart Claude Code to apply."

  if [[ "$relaunch" == "--relaunch" ]]; then
    # Intentionally unquoted: CCSWITCH_CLAUDE_CMD may hold a command plus
    # arguments (e.g. "claude --resume"), and relying on word-splitting here
    # is how those arguments reach exec. Do not "fix" this by quoting it.
    # shellcheck disable=SC2086
    exec ${CCSWITCH_CLAUDE_CMD:-claude}
  fi
}

usage_text() {
  cat <<'EOF'
ccswitch: save, list, switch between, and delete Claude Code accounts.

Usage:
  ccswitch                     list saved accounts (same as `list`)
  ccswitch list                list saved accounts, '*' marks the active one
  ccswitch save <label>        snapshot the currently active account
  ccswitch delete <label>      remove a saved account (prompts to confirm)
  ccswitch <label> [--relaunch]
                                switch to a saved account; --relaunch execs
                                the claude CLI afterward (override with
                                CCSWITCH_CLAUDE_CMD)
EOF
}

main() {
  local cmd="${1:-}"

  case "$cmd" in
    save)
      shift
      cmd_save "${1:-}"
      ;;
    delete)
      shift
      cmd_delete "${1:-}"
      ;;
    list | "")
      cmd_list
      ;;
    usage)
      # Task 3 replaces this stub with the real usage-monitor subcommand.
      echo "usage monitor not yet implemented"
      ;;
    -h | --help)
      usage_text
      ;;
    -*)
      echo "Error: unknown option '$cmd'." >&2
      exit 1
      ;;
    *)
      cmd_switch "$cmd" "${2:-}"
      ;;
  esac
}

main "$@"
